exports[`LQIP > blurhash LQIP is supported 1`] = `
"import { findMatchingImage as a } from "@responsive-image/core";
import { decode2url as t } from "@responsive-image/core/blurhash/decode";
const o = [{
  url: "/image-100w.jpg",
  width: 100,
  format: "jpeg"
}, {
  url: "/image-100w.webp",
  width: 100,
  format: "webp"
}, {
  url: "/image-200w.jpg",
  width: 200,
  format: "jpeg"
}, {
  url: "/image-200w.webp",
  width: 200,
  format: "webp"
}], g = {
  imageTypes: [
    "jpeg",
    "webp"
  ],
  availableWidths: [
    100,
    200
  ],
  aspectRatio: 1.5,
  imageUrlFor: (e, i) => a(o, e, i ?? "jpeg")?.url,
  lqip: {
    inlineStyles: () => ({ "background-image": \`url("\${t("M53KT1R8D8y.t2M.oxylRoRlHYniyBRQXR", 5, 3)}")\` }),
    attribute: "bh:5:3:M53KT1R8D8y.t2M.oxylRoRlHYniyBRQXR"
  }
};
console.log(g);
"
`;

