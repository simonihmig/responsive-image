{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergePatch",
    ":automergeLinters",
    ":automergeTesters",
    ":automergeTypes",
    ":maintainLockFilesWeekly",
    ":semanticCommitsDisabled",
    "config:js-lib"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchCurrentVersion": ">= 1.0.0",
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    // Do not attempt to upgrade Embroider from v3 to v4, since they are fundamentally different
    {
      "matchPackageNames": ["@embroider/core", "@embroider/compat"],
      "matchUpdateTypes": ["major"],
      "matchCurrentVersion": "^3.0.0",
      "enabled": false
    },
    // Leave ember-webpack (Embroider v3) at Ember v6
    {
      "matchPackageNames": ["ember-source"],
      "sourceDirectory": "apps/ember-webpack",
      "allowedVersions": "^6.12.0"
    }
  ],
  "baseBranchPatterns": ["main"],
  "postUpdateOptions": ["pnpmDedupe"]
}
