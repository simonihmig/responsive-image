{
  "name": "@responsive-image/vite-plugin",
  "version": "2.0.2",
  "description": "Vite plugins to process and resize responsive images",
  "repository": "github:simonihmig/responsive-image",
  "license": "MIT",
  "author": "Simon Ihmig <simon.ihmig@gmail.com>",
  "files": [
    "dist",
    "client.d.ts"
  ],
  "type": "module",
  "keywords": [
    "responsive image",
    "responsive images",
    "vite-plugin",
    "vite plugin",
    "vite"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./client": {
      "import": {
        "types": "./client.d.ts"
      }
    }
  },
  "scripts": {
    "build": "pkgroll",
    "lint:fix": "concurrently 'npm:lint.*:fix' --names 'fix:'",
    "lint.eslint": "eslint .",
    "lint.eslint:fix": "eslint . --fix",
    "lint.publint": "publint",
    "lint.prettier": "prettier . --check",
    "lint.prettier:fix": "prettier . --write",
    "lint.types": "tsc --noEmit",
    "prepack": "pnpm turbo build",
    "start": "pkgroll --watch",
    "test.vitest": "vitest run",
    "test.vitest:watch": "vitest watch"
  },
  "dependencies": {
    "@responsive-image/build-utils": "workspace:^",
    "@responsive-image/core": "workspace:^",
    "blurhash": "^2.0.4",
    "imagetools-core": "^9.0.0",
    "sharp": "^0.34.0",
    "thumbhash": "^0.1.1"
  },
  "devDependencies": {
    "@responsive-image/internals": "workspace:*",
    "@tsconfig/node22": "22.0.5",
    "@types/jest-image-snapshot": "6.4.1",
    "@types/node": "22.19.15",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
    "glob": "13.0.6",
    "jest-image-snapshot": "6.5.2",
    "pkgroll": "2.27.0",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "typescript": "5.9.3",
    "vite": "8.0.2",
    "vitest": "4.1.1"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "compatiblePackages": {
    "schemaVersion": 1,
    "rolldown": {
      "type": "incompatible",
      "reason": "Uses Vite-specific APIs"
    },
    "rollup": {
      "type": "incompatible",
      "reason": "Uses Vite-specific APIs"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": "22.* || >= 24"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
