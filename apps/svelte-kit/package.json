{
  "name": "svelte-kit",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint.eslint": "eslint .",
    "lint.eslint:fix": "eslint . --fix",
    "lint.prettier": "prettier . --check",
    "lint.prettier:fix": "prettier . --write",
    "lint.svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint.svelte:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test.playwright": "playwright test",
    "testplaywright:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.4",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@responsive-image/cdn": "workspace:*",
    "@responsive-image/core": "workspace:*",
    "@responsive-image/svelte": "workspace:*",
    "@responsive-image/internals": "workspace:*",
    "@responsive-image/vite-plugin": "workspace:*",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.56.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@types/node": "22.19.17",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.17.0",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.55.1",
    "svelte-check": "4.4.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3"
  }
}
